# =====================================================================
# SNS AutoPost — 環境変数テンプレート
# =====================================================================
# このファイルを `.env.local` にコピーして値を埋めてください。
# Vercel に投入する場合は Project Settings → Environment Variables から。
#
# キーは大きく 3 グループに分かれます:
#   (A) 必須              … これが無いとアプリ起動しない
#   (B) 動画機能           … 動画パイプライン / TikTok / YouTube 投稿
#   (C) 任意 / 本番運用    … パフォーマンス・本番ジョブ実行基盤
#
# AI 系（OpenRouter / OpenAI / ElevenLabs）の API キーは原則
# **ユーザーが「設定」ページで登録**します（暗号化して DB に保存）。
# env に書く必要があるのは ElevenLabs だけ（任意・フォールバック用）。
# =====================================================================


# ---------------------------------------------------------------------
# (A) 必須
# ---------------------------------------------------------------------

# Supabase 接続
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...                   # publishable key (sb_publishable_...) でも可
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...                       # 機密。サーバー側でのみ使用

# DB に保存する API キー等を暗号化する鍵（32 バイト base64）
#   生成例: openssl rand -base64 32
# ⚠️ 本番で既に運用中の場合、変更すると既存暗号化データを復号できなくなる
ENCRYPTION_KEY=base64-encoded-32-bytes-here

# 鍵ローテーション時のみ使用（古い鍵で復号 → 新しい鍵で再暗号化）
# ENCRYPTION_KEY_OLD=

# アプリ URL（OpenRouter Referer ヘッダ / OAuth redirect 生成に使う）
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app


# ---------------------------------------------------------------------
# (B) 動画機能 — 動画生成 + TikTok/YouTube 投稿
# ---------------------------------------------------------------------

# ElevenLabs（音声合成）
#   通常はユーザーが「設定」ページから登録します。env はフォールバック。
# ELEVENLABS_API_KEY=sk_...

# --- TikTok 投稿（Content Posting API）---
# Developer Portal: https://developers.tiktok.com/apps
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
# TIKTOK_REDIRECT_URI=https://your-app.vercel.app/api/auth/tiktok/callback

# --- YouTube 投稿（Data API v3）---
# Google Cloud Console: https://console.cloud.google.com/apis/credentials
# YOUTUBE_OAUTH_CLIENT_ID=
# YOUTUBE_OAUTH_CLIENT_SECRET=
# YOUTUBE_OAUTH_REDIRECT_URI=https://your-app.vercel.app/api/auth/youtube/callback


# ---------------------------------------------------------------------
# (C) 任意 / 本番運用
# ---------------------------------------------------------------------

# Trigger.dev（バックグラウンドジョブ基盤）
#   未設定なら setImmediate フォールバック（Vercel 60s 制限で長尺レンダリングが切れる）
#   本番運用には設定推奨: https://trigger.dev
# TRIGGER_PUBLIC_API_KEY=

# Remotion レンダリング先
#   - 未設定 / "local" → ローカル Chromium で実行（Vercel Functions では動かない）
#   - "lambda" → @remotion/lambda 経由（要 AWS セットアップ、現状 TODO）
# REMOTION_PROVIDER=local

# Remotion bundle のキャッシュ先（任意）
# REMOTION_BUNDLE_PATH=
