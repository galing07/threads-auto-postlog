# =====================================================================
# SNS AutoPost — Template Environment Variable
# =====================================================================
# Salin file ini menjadi `.env.local` lalu isi nilainya.
# Untuk Vercel, masukkan melalui Project Settings → Environment Variables.
#
# Variabel dibagi menjadi 3 grup besar:
# (A) Wajib      → Tanpa ini aplikasi tidak bisa jalan
# (B) Fitur Video → Video pipeline, TikTok, dan YouTube
# (C) Opsional / Produksi → Untuk performa dan job background
#
# API Key AI (OpenRouter / OpenAI / ElevenLabs) **tidak disimpan di sini**.
# User harus mendaftarkannya sendiri melalui halaman "Pengaturan"
# di dalam aplikasi (disimpan dengan enkripsi AES-256-GCM).
# =====================================================================

# ---------------------------------------------------------------------
# (A) WAJIB
# ---------------------------------------------------------------------
# Supabase Connection
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi... # publishable key (sb_publishable_...) juga boleh
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi... # Rahasia. Hanya digunakan di server
# Kunci enkripsi untuk menyimpan API Key di database (32 byte base64)
# Contoh generate: openssl rand -base64 32
# ⚠️ Jika sudah digunakan di produksi, jangan ubah! Karena data lama tidak bisa dibuka.
ENCRYPTION_KEY=base64-encoded-32-bytes-here

# Kunci lama (hanya digunakan saat rotasi kunci)
# ENCRYPTION_KEY_OLD=

# URL Aplikasi (digunakan untuk OAuth redirect dan Referer header)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ---------------------------------------------------------------------
# (B) FITUR VIDEO — Video Generation + TikTok / YouTube Posting
# ---------------------------------------------------------------------
# ElevenLabs (Text-to-Speech)
# User WAJIB daftarkan sendiri di halaman Pengaturan.
# Fallback di env sudah dihapus.

# --- TikTok Posting (Content Posting API) ---
# Daftar di: https://developers.tiktok.com/apps
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
# TIKTOK_REDIRECT_URI=https://your-app.vercel.app/api/auth/tiktok/callback

# --- YouTube Posting (Data API v3) ---
# Daftar di: https://console.cloud.google.com/apis/credentials
# YOUTUBE_OAUTH_CLIENT_ID=
# YOUTUBE_OAUTH_CLIENT_SECRET=
# YOUTUBE_OAUTH_REDIRECT_URI=https://your-app.vercel.app/api/auth/youtube/callback

# --- X (Twitter) OAuth ---
# Client ID & Secret TIDAK disimpan di env, tapi didaftarkan user sendiri
# melalui panel "Akun → X" di dalam aplikasi (sama seperti Instagram).
# X_OAUTH_REDIRECT_URI=https://your-app.vercel.app/api/auth/x/callback

# ---------------------------------------------------------------------
# (C) OPSIONAL / UNTUK PRODUKSI
# ---------------------------------------------------------------------
# Trigger.dev (Background Job)
# Jika kosong akan pakai setImmediate (bisa timeout di Vercel)
TRIGGER_PUBLIC_API_KEY=

# Remotion Rendering Provider
# "local" (default) → Hanya jalan di lokal
# "lambda" → Via @remotion/lambda (masih TODO)
# REMOTION_PROVIDER=local

# Path cache bundle Remotion
# REMOTION_BUNDLE_PATH=
